PORT=5000
DATABASE_URL=postgresql://postgres:password@db.your-supabase-host.supabase.co:5432/postgres?schema=public
JWT_SECRET=replace-with-a-strong-jwt-secret
JWT_EXPIRES_IN=8h
# ENCRYPTION_KEY must be 32 bytes (UTF-8), 64-char hex, or base64-encoded 32-byte key.
ENCRYPTION_KEY=replace-with-32-byte-encryption-key
QR_TOKEN_TTL_MS=300000
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15555550123
